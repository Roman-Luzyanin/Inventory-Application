<div class="changeSubCategory" >
    <form  method="post" class="newCategory" id="changeSubCategoryForm" enctype="multipart/form-data">
        <label for="subNameUpdate">New name</label>
        <input type="text" name="name" id="subNameUpdate">

        <label>Image:</label>
        <div class="previewImg" onclick="removeImg()">
            <img class="subPreviewSrc">
        </div>
        <input type="file" name="image" id="changeSubCategoryFile">

        <input type="hidden" name="removeImg" class="removeImg">
        <input type="hidden" name="parent_id" id="parent_id">
        <button type="submit">update</button>
        <button type="button" onclick="changeSubCategory()">cancel</button>
    </form>          
</div>

<% if (searchedItems.length > 0) { %>
    <div class="items">
        <% searchedItems.forEach(item => { %>
            <div class="item">
                <img src="<%= item.image_url || 'placeholder/image.png' %>" class="itemImage">

                <form action="/delete/item/<%= item.id %>" method="post" class="delItem">
                    <input type="hidden" name="categoryId" value="<%= categoryId %>">
                    <input type="hidden" name="subCategoryId" value="<%= subCategoryId %>">
                    <button type="submit"></button>
                </form>

                <form action="/" method="get" class="itemForm">
                    <input type="hidden" name="categoryId" value="<%= categoryId %>">
                    <input type="hidden" name="subCategoryId" value="<%= subCategoryId %>">
                    <input type="hidden" name="itemId" value="<%= item.id %>">
                    <button type="submit"><%= item.name %></button>
                </form>
            </div>
        <% }) %>
    </div>
<% } else if (searchedSubCat.length > 0) { %>
    <div class="subCategories">
        <% searchedSubCat.forEach(subCategory => { %>
            <div class="subCategoryRight">
                <img src="<%= subCategory.image_url || 'placeholder/image.png' %>" class="subImage">

                <form action="/delete/subCategory/<%= subCategory.id %>" method="post" class="delSubCat">
                    <input type="hidden" name="categoryId" value="<%= categoryId %>">
                    <button type="submit"></button>
                </form>

                <button 
                    type="button"
                    class="changeSubCategoryBtn"
                    data-id="<%= subCategory.id %>"
                    data-name="<%= subCategory.name %>"
                    data-parent="<%= subCategory.parent_id %>"
                    data-url="<%= subCategory.image_url %>"
                ></button>
                
                <form action="/" method="get" class="subCategoryForm">
                    <input type="hidden" name="categoryId" value="<%= categoryId %>">
                    <input type="hidden" name="subCategoryId" value="<%= subCategory.id %>">
                    <button type="submit"><%= subCategory.name %></button>
                </form>
            </div>
        <% }) %>
    </div>
<% } else if(searchedPromo.length > 0) { %>
    <div class="items">
        <% searchedPromo.forEach(item => { %>
            <div class="item">
                <img src="<%= item.image_url || 'placeholder/image.png' %>" class="itemImage">

                <form action="/update/depromote/<%= item.id %>" method="post" class="delPromo">
                    <input type="hidden" name="itemNameUpdate" value="<%= item.name %>">
                    <input type="hidden" name="imagePath" value="">
                    <input type="hidden" name="descriptionUpdate" value="<%= item.description %>">
                    <input type="hidden" name="isPromoteUpt" value='false'>
                    <input type="hidden" name="removeImg" value="">
                    <button type="submit"></button>
                </form>

                <form action="/" method="get" class="itemForm">
                    <input type="hidden" name="categoryId" value="<%= item.root_id %>">
                    <input type="hidden" name="subCategoryId" value="<%= item.category_id %>">
                    <input type="hidden" name="itemId" value="<%= item.id %>">
                    <button type="submit"><%= item.name %></button>
                </form>
            </div>
        <% }) %>
    </div>  
<% } %>