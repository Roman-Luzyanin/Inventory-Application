<div class="changeItem" >
    <form action="/update/item/<%= item.id %>" method="post" class="newCategory" id="changeItemForm" enctype="multipart/form-data">
        <div>
            <label for="itemNameUpdate">New name:</label>
            <input type="text" name="itemNameUpdate" id="itemNameUpdate" value="<%= item.name %>" minlength="3" maxlength="30" required  tabindex="-1">
            
            <div class="placeAtHome">
                <label>Place at HOME:</label>
                <input type="checkbox" name="isPromoteUpt" id="isPromoteUpt" <%= item.promote ? 'checked' : '' %> /  tabindex="-1">
            </div>

            <label>Image:</label>
            <div class="previewImg" onclick="removeImg()">
                <img src="<%= item.image_url %>">
            </div>
            <input type="file" name="image" id="updateItemFile"  tabindex="-1">

            <input type="hidden" name="removeImg" class="removeImg">
            <input type="hidden" name="categoryId" value="<%= categoryId %>">
            <input type="hidden" name="subCategoryId" value="<%= subCategoryId %>">
            <input type="hidden" name="itemId" value="<%= itemId %>">
            
            <div>
                <button type="submit"  tabindex="-1">apply</button>
                <button type="button" onclick="changeItem()"  tabindex="-1">cancel</button>
            </div>
        </div>
        <div>
            <label for="descriptionUpdate">Description:</label>
            <textarea name="descriptionUpdate" id="descriptionUpdate"  tabindex="-1"><%= item.description %></textarea>
        </div>
    </form>          
</div>

<div class="itemDetails">
    <button class="changeItemDetailsBtn" onclick="itemPasswordCheck()"></button>

    <div class="itemPassword">
        <label >Password:</label>
        <input type="text" >
        <button 
            type="button"  
            class="changeItemDetails"
            data-url="<%= item.image_url %>" 
            data-name="<%= item.name %>"
            data-description="<%= item.description %>"
            data-promote="<%= item.promote ? 'true' : '' %>"
        >Ok</button>
        <button onclick="itemPasswordCheck()">Cancel</button>
    </div>

    <h1><%= item.name %></h1>
 
    <div class="description">
        <img src="<%= item.image_url || 'placeholder/image.png' %>">
        <p><%= item.description %></p>
    </div>
    
</div>
